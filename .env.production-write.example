# Production-write beta example. Copy to a private .env file; never commit real values.

MISP_URL=https://misp.example.org
MISP_API_KEY=replace-with-runtime-secret
MISP_VERIFY_TLS=true
MISP_TIMEOUT_SECONDS=30

AGENTIC_MISP_MCP_ROLE=analyst_write
AGENTIC_MISP_MCP_ENABLE_WRITE=true
AGENTIC_MISP_MCP_REQUIRE_APPROVAL=true
AGENTIC_MISP_MCP_APPROVAL_MODE=production
AGENTIC_MISP_MCP_APPROVAL_STORE_PATH=/var/lib/agentic-misp-mcp/approvals.sqlite3
AGENTIC_MISP_MCP_APPROVAL_TTL_SECONDS=900

# Publishing is disabled by default and should normally live in a separate curator deployment.
AGENTIC_MISP_MCP_ENABLE_PUBLISH=false

# Optional defense-in-depth allowlists. Empty/unset means allow all.
AGENTIC_MISP_MCP_ALLOWED_ATTRIBUTE_TYPES=ip-dst,ip-src,url,domain
AGENTIC_MISP_MCP_ALLOWED_ATTRIBUTE_CATEGORIES=Network activity,Payload delivery
AGENTIC_MISP_MCP_ALLOWED_TAGS=tlp:*,misp-galaxy:*

AGENTIC_MISP_MCP_AUDIT_LOG_PATH=/var/log/agentic-misp-mcp/audit.jsonl
AGENTIC_MISP_MCP_LOG_LEVEL=INFO
AGENTIC_MISP_MCP_MAX_RESPONSE_BYTES=5242880
AGENTIC_MISP_MCP_ALLOW_INSECURE_HTTP_BIND=false
