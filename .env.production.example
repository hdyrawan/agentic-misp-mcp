# Production-oriented environment template for agentic-misp-mcp.
#
# This file contains placeholders only. Copy it to `.env` (or a runtime-only secrets store)
# and replace every placeholder with real values. Never commit the resulting file.
#
# Defaults below are the conservative production baseline described in
# docs/production-readiness.md: TLS verification on, read-only role, writes disabled, approval
# required, and no insecure HTTP bind. Do not weaken these defaults without reading that document
# and completing its acceptance criteria first.

# --- Required: MISP connection ---
MISP_URL=https://misp.example.local
MISP_API_KEY=replace_with_a_real_misp_api_key

# --- TLS: keep verification on for any real deployment ---
# MISP_VERIFY_TLS=false is lab-only, for a self-signed certificate on an isolated MISP lab.
# Never set this to false against a real MISP instance.
MISP_VERIFY_TLS=true

# --- Request limits ---
MISP_TIMEOUT_SECONDS=30
MISP_DEFAULT_LIMIT=20
MISP_MAX_LIMIT=100
MISP_EVENT_ATTRIBUTE_LIMIT=50
MISP_RELATED_EVENT_LIMIT=5

# --- Audit logging ---
# Point this at a host-writable, persisted path. In Docker, mount a volume at /app/logs and set
# this to /app/logs/audit.jsonl (see docs/production-readiness.md's Docker hardening checklist).
AGENTIC_MISP_MCP_AUDIT_LOG_PATH=/path/to/agentic-misp-mcp/logs/audit.jsonl
AGENTIC_MISP_MCP_LOG_LEVEL=INFO

# --- Policy: read-only, writes disabled, approval required ---
# This is the only combination validated for production use so far (see
# docs/production-readiness.md). Changing any of the three lines below moves you into the
# controlled-write path, which has only been validated in a lab, not in production.
AGENTIC_MISP_MCP_ROLE=read_only
AGENTIC_MISP_MCP_ENABLE_WRITE=false
AGENTIC_MISP_MCP_REQUIRE_APPROVAL=true

# --- Approval-token hardening (optional, recommended if you ever enable writes) ---
# Leave this unset (commented out) for a read-only deployment. Do NOT uncomment this line and
# leave the value blank (`AGENTIC_MISP_MCP_APPROVAL_TOKEN=`) — a blank value is easy to mistake
# for "no token configured" when reading the file, even though the server normalizes it to unset
# either way. If you do enable controlled writes, generate a real random token (for example
# `openssl rand -hex 32`) and set it explicitly:
# AGENTIC_MISP_MCP_APPROVAL_TOKEN=replace_with_a_long_random_token

# --- Response size cap ---
AGENTIC_MISP_MCP_MAX_RESPONSE_BYTES=5242880

# --- HTTP transport: keep disabled/insecure-bind off ---
# stdio is the only transport validated for production use. HTTP transport is experimental and
# must stay off 0.0.0.0 unless it sits behind an authenticated, TLS-terminating gateway.
AGENTIC_MISP_MCP_ALLOW_INSECURE_HTTP_BIND=false
